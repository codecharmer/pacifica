{
  "name": "pacifica/core",
  "description": "Pacífica Core — commerce, reserve-&-pickup ordering, Stripe, Twilio SMS workflow, SEO schema, and admin dashboard for Pacífica Panadería. All business logic lives here.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Pacífica Panadería — Agency Build",
      "homepage": "https://pacifica.mx/"
    }
  ],
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "php-stubs/wordpress-stubs": "^6.8",
    "php-stubs/woocommerce-stubs": "^9.0"
  },
  "autoload": {
    "psr-4": {
      "Pacifica\\Core\\": "src/"
    }
  },
  "scripts": {
    "lint": "phpcs -q",
    "lint:fix": "phpcbf"
  },
  "scripts-descriptions": {
    "lint": "Run coding-standards checks against this plugin's src/.",
    "lint:fix": "Auto-fix fixable coding-standards violations in this plugin."
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.3.0"
    },
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
