{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Horno de Noche",
	"description": "Paleta oscura para secciones: fondo corteza y texto masa, con acentos de trigo. Ideal para portadas y franjas nocturnas.",
	"styles": {
		"color": {
			"background": "var:preset|color|crust",
			"text": "var:preset|color|masa"
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var:preset|color|linen"
				}
			},
			"h2": {
				"color": {
					"text": "var:preset|color|linen"
				}
			},
			"h3": {
				"color": {
					"text": "var:preset|color|linen"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|trigo"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|ember"
					}
				},
				":focus": {
					"color": {
						"text": "var:preset|color|ember"
					}
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|trigo",
					"text": "var:preset|color|crust"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|ember",
						"text": "var:preset|color|crust"
					}
				},
				":focus": {
					"color": {
						"background": "var:preset|color|ember",
						"text": "var:preset|color|crust"
					}
				}
			},
			"caption": {
				"color": {
					"text": "var:preset|color|stone"
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"color": {
					"text": "var:preset|color|linen"
				}
			}
		}
	}
}
