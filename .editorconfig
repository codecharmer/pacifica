# EditorConfig — https://editorconfig.org
# Aligned with WordPress coding standards (tabs for PHP/JS/CSS).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

# WordPress convention: real tabs for code.
[*.{php,js,jsx,ts,tsx,css,scss,html}]
indent_style = tab

# Data/config formats use spaces.
[*.{json,yml,yaml,neon}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.xml]
indent_style = tab

[{package.json,composer.json,.nvmrc}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
